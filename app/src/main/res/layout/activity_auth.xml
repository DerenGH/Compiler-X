<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:padding="24dp">

    <TextView
        android:id="@+id/authTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="64dp"
        android:fontFamily="sans-serif-medium"
        android:text="Compiler-X"
        android:textColor="#FFFFFF"
        android:textSize="32sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextSwitcher
        android:id="@+id/authHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/authTitle">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="LOG IN"
            android:textColor="#4CAF50"
            android:textSize="18sp" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="REGISTER"
            android:textColor="#4CAF50"
            android:textSize="18sp" />
    </TextSwitcher>

    <LinearLayout
        android:id="@+id/authFormContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:background="#1E1E1E"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/authHeader">

        <EditText
            android:id="@+id/etAuthUsername"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#2D2D2D"
            android:fontFamily="monospace"
            android:hint="Username"
            android:inputType="text"
            android:paddingStart="16dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#808080"
            android:visibility="gone" />

        <EditText
            android:id="@+id/etAuthEmail"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#2D2D2D"
            android:fontFamily="monospace"
            android:hint="Email"
            android:inputType="textEmailAddress"
            android:paddingStart="16dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#808080" />

        <EditText
            android:id="@+id/etAuthPassword"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#2D2D2D"
            android:fontFamily="monospace"
            android:hint="Password"
            android:inputType="textPassword"
            android:paddingStart="16dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#808080" />

        <EditText
            android:id="@+id/etAuthRepeatPassword"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#2D2D2D"
            android:fontFamily="monospace"
            android:hint="Repeat Password"
            android:inputType="textPassword"
            android:paddingStart="16dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#808080"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnAuthAction"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:backgroundTint="#4CAF50"
            android:fontFamily="monospace"
            android:text="LOG IN"
            android:textColor="#FFFFFF"
            app:cornerRadius="12dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvAuthModeToggle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:fontFamily="monospace"
        android:text="Not Registered? (CREATE ACCOUNT)"
        android:textColor="#40FFFFFF"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/authFormContainer" />

</androidx.constraintlayout.widget.ConstraintLayout>